{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Unity Log Viewer",
  "mainBinaryName": "UnityLogViewer",
  "version": "1.2.0",
  "identifier": "com.bwaynesu.unitylogviewer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Unity Log Viewer",
        "width": 1280,
        "height": 800,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/bwaynesu/UnityLogViewer/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE5MkNFOEIyREE5MjAzMTQKUldRVUE1TGFzdWdzcVZIeWNPd01tQkhsM3UvaW8xNU9Xd0ZoQnl5ZzM4ajlzWENyY2t1b0pOUDEK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "resources": ["installed.marker"],
    "windows": {
      "nsis": {
        "installerHooks": "./nsis-hooks.nsh"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
